rules_version = '2';

// Storage de GlobalPlay360.
// Contingut real del bucket:
//   - users/{uid}/avatar.jpg  → imatge facial (dada personal, RGPD)
//   - fitxers de màrqueting (vídeos, fons del Sidebar) pujats via consola
//
// Els assets de màrqueting es consumeixen amb URLs de descàrrega amb token
// (`?alt=media&token=...`), que NO passen per aquestes rules — no necessiten
// cap match. Tot el que no coincideix amb cap match queda DENEGAT per
// defecte: cap client pot escriure fora del seu propi directori d'usuari.
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatars d'usuari ─────────────────────────────────
    // Lectura via SDK: només usuaris autenticats (el marketplace és privat).
    // Escriptura: només el propietari, imatges reals i màxim 5 MB
    // (mateix límit que valida el client a ProfilePage).
    match /users/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
