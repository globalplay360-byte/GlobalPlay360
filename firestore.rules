rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ────────────────────────────────────────────
    // Font de veritat del pla de l'usuari = custom claim `stripeRole` que
    // escriu l'extensió `firestore-stripe-payments` al JWT quan una subscripció
    // està activa o en trial. Cap via perquè el client ho falsifiqui.
    //
    // Valors esperats: 'premium' (inclou trialing), 'pro', o absent/null per free.
    // NOTA operativa: després d'un checkout, el client ha de forçar refresh del token
    // (auth.currentUser.getIdToken(true)) perquè la claim apareixi al JWT actiu.
    function hasPremium() {
      return request.auth != null
             && request.auth.token.stripeRole in ['premium', 'pro'];
    }

    function hasValidSingleSession() {
      return request.auth != null
             && exists(/databases/$(database)/documents/auth_sessions/$(request.auth.uid))
             && request.auth.token.auth_time >= get(/databases/$(database)/documents/auth_sessions/$(request.auth.uid)).data.validAfterSeconds;
    }

    // Admin role check: l'admin té accés de lectura ampla per al panell de
    // gestió. Cost: 1 document read per rule check (acceptable per a un panell
    // d'ús esporàdic). Per migrar a custom claims `admin: true` cal una Cloud
    // Function que els assigni; aquesta versió funciona sense infraestructura.
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── USERS ──────────────────────────────────────────────
    // Doc `users/{uid}` conté NOMÉS camps públics (displayName, role, bio, sport,
    // country, position, height, etc.) necessaris per al marketplace.
    // Els camps sensibles (email, phone, instagram, youtubeVideoUrl, dateOfBirth)
    // viuen a la subcol·lecció `users/{uid}/private/profile` amb rule pròpia.
    // Hardening SaaS: la identitat dels clubs NO és pública per a usuaris Free.
    // Un usuari autenticat només pot llegir docs de clubs si és el propietari,
    // admin o té Premium. Players i coaches continuen sent visibles al marketplace.
    match /users/{userId} {
      allow read: if hasValidSingleSession()
                  && (
                    request.auth.uid == userId
                    || isAdmin()
                    || resource.data.role != 'club'
                    || hasPremium()
                  );
      allow create: if request.auth != null && request.auth.uid == userId;

      // Actualització de perfil:
      // Només deixem editar si és el seu propi perfil.
      // I si el paquet conté intents d'editar camps sensibles, assegurem-nos
      // que no els està canviant pel que ja tenien (evita regalar-se Premium).
      allow update: if hasValidSingleSession()
                    && (
                      (
                        request.auth.uid == userId
                        && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == resource.data.role)
                        && (!request.resource.data.keys().hasAll(['plan']) || request.resource.data.plan == resource.data.plan)
                        && (!request.resource.data.keys().hasAll(['email']) || request.resource.data.email == resource.data.email)
                      )
                      || (
                        isAdmin()
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['role'])
                      )
                    );

      allow delete: if false;

      // ── Subcol·lecció privada (PII + camps Premium-gated) ──
      // Lectura: propietari SEMPRE, o qualsevol amb claim stripeRole='premium'|'pro'.
      // Escriptura: només el propietari.
      // Defense in depth: un Free autenticat rep DENY encara que manipuli el SDK.
      match /private/{docId} {
        allow read: if hasValidSingleSession()
                    && (request.auth.uid == userId || hasPremium());
        allow create, update: if hasValidSingleSession() && request.auth.uid == userId;
        allow delete: if false;
      }
    }

    // ── OPPORTUNITIES ──────────────────────────────────────
    match /opportunities/{opportunityId} {
      allow read: if true;
      allow create: if hasValidSingleSession();
      allow update, delete: if hasValidSingleSession()
                            && (request.auth.uid == resource.data.clubId || isAdmin());
    }

    // ── APPLICATIONS ───────────────────────────────────────
    // Només players/coaches poden crear candidatures. Els clubs mai (ni amb el
    // seu propi uid com a userId) — un club no aplica a les seves pròpies ofertes
    // ni pot suplantar un candidat. Comprovem el role des del doc users/{uid}.
    match /applications/{applicationId} {
      allow read: if hasValidSingleSession()
                  && (request.auth.uid == resource.data.userId
                      || request.auth.uid == resource.data.clubId
                      || isAdmin());
      allow create: if hasValidSingleSession()
                    && request.auth.uid == request.resource.data.userId
                    && request.auth.uid != request.resource.data.clubId
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid))
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'club';
      allow update: if hasValidSingleSession()
                    && (
                      (
                        request.auth.uid == resource.data.clubId
                        && request.resource.data.clubId == resource.data.clubId
                        && request.resource.data.userId == resource.data.userId
                        && request.resource.data.opportunityId == resource.data.opportunityId
                      )
                      || isAdmin()
                    );
      allow delete: if hasValidSingleSession()
                    && (
                      request.auth.uid == resource.data.userId
                      || request.auth.uid == resource.data.clubId
                      || isAdmin()
                    );
    }

    // ── CONVERSATIONS (Missatgeria) ────────────────────────
    // Estratègia defense-in-depth + preservació del Teaser Paywall:
    //
    //   READ conversation metadata (participants, lastMessage, unreadCount, hasMessages):
    //     → només participant. Els Free també ho poden llegir per veure la llista
    //       del Teaser Paywall (badge "Missatge protegit", comptador d'unreads al
    //       Sidebar). Hardening SaaS: ja NO persistim el text del preview al doc
    //       de conversa; `lastMessage` es manté buit i `hasMessages` només indica
    //       si el fil té activitat, evitant filtracions de contingut o identitat.
    //
    //   WRITE conversation (create/update metadata, markAsRead, etc):
    //     → participant + Premium. Impedeix que un Free manipuli el client per
    //       iniciar converses o actualitzar metadata.
    //
    //   READ/WRITE messages subcollection (contingut real):
    //     → participant + Premium. És el nucli de la protecció. Encara que el
    //       Free sigui participant legítim, mai podrà llegir el text dels
    //       missatges via API si no té claim premium/pro.
    match /conversations/{conversationId} {
      allow read: if hasValidSingleSession()
                  && (request.auth.uid in resource.data.participants || isAdmin());

      allow create: if hasValidSingleSession()
                    && request.auth.uid in request.resource.data.participants
                    && hasPremium();

      allow update, delete: if hasValidSingleSession()
                            && (
                              (request.auth.uid in resource.data.participants && hasPremium())
                              || isAdmin()
                            );

      match /messages/{messageId} {
        allow read, write: if hasValidSingleSession()
                           && (
                             isAdmin()
                             || (
                               request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                               && hasPremium()
                             )
                           );
      }
    }

    // ── ADMIN AUDIT LOGS ─────────────────────────────────
    // Traçabilitat immutable de moderacions i canvis sensibles fets des del panell admin.
    // Només l'admin pot crear i llegir aquests registres; no s'editen ni s'esborren.
    match /admin_audit_logs/{logId} {
      allow read, create: if hasValidSingleSession() && isAdmin();
      allow update, delete: if false;
    }

    match /auth_sessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── STRIPE: PRODUCTS ───────────────────────────────────
    // Sincronitzats des de Stripe via webhook (extensió escriu amb Admin SDK, bypassa rules).
    // Lectura pública: la PricingPage ha de mostrar els plans fins i tot a usuaris no registrats.
    // Cap escriptura del client: la font de veritat és Stripe.
    match /products/{productId} {
      allow read: if true;
      allow write: if false;

      match /prices/{priceId} {
        allow read: if true;
        allow write: if false;
      }

      match /tax_rates/{taxRateId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── STRIPE: CUSTOMERS ──────────────────────────────────
    // Un doc per usuari autenticat, creat lazy per l'extensió al primer checkout.
    // El client NO pot escriure al doc customer — ho fa només l'extensió amb Admin SDK.
    match /customers/{uid} {
      allow read: if hasValidSingleSession() && request.auth.uid == uid;
      allow write: if false;

      // Checkout sessions: el client en CREA una per iniciar un checkout (amb price, success_url, etc.);
      // l'extensió hi escriu després la URL de Stripe (amb Admin SDK, bypassa rules).
      // Permetem create + read del propi uid. Ni update ni delete (immutables).
      // NOTA: el Customer Portal no usa aquest patró, es crida via Callable Function
      // `ext-firestore-stripe-payments-createPortalLink`.
      match /checkout_sessions/{sessionId} {
        allow read: if hasValidSingleSession() && request.auth.uid == uid;
        allow create: if hasValidSingleSession() && request.auth.uid == uid;
        allow update, delete: if false;
      }

      // Subscripcions: sync des de Stripe via webhook. Només lectura del propi uid.
      // Font de veritat del plan de l'usuari: aquesta col·lecció.
      match /subscriptions/{subscriptionId} {
        allow read: if hasValidSingleSession() && request.auth.uid == uid;
        allow write: if false;
      }

      // Payments / invoices: sync des de Stripe via webhook. Només lectura del propi uid.
      match /payments/{paymentId} {
        allow read: if hasValidSingleSession() && request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}
